<roblox xmlns:xmime="http://www.w3.org/2005/05/xmlmime" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="http://www.roblox.com/roblox.xsd" version="4">
	<External>null</External>
	<External>nil</External>
	<Item class="Script" referent="RBX720F7D4DF1A846A197707EC30BE83CDD">
		<Properties>
			<ProtectedString name="Source"><![CDATA[local RunService = game:GetService("RunService")
local HttpService = game:GetService("HttpService")

local CLEAN_URL = "http://localhost:9088/clean"

local function triggerClean()
	task.spawn(function()
		local success, err = pcall(function()
			return HttpService:PostAsync(CLEAN_URL, "")
		end)
		if success then
			print("[Memory Optimizer] RAM cleared successfully on playtest stop.")
		else
			warn("[Memory Optimizer] Failed to clear RAM: " .. tostring(err))
		end
	end)
end
if not RunService:IsEdit() and RunService:IsServer() then
	game:BindToClose(function()
		triggerClean()
		task.wait(0.5) 
	end)
end]]></ProtectedString>
			<bool name="Disabled">false</bool>
			<Content name="LinkedSource"><null></null></Content>
			<token name="RunContext">0</token>
			<string name="ScriptGuid">{E63595BC-D2C6-4C5C-A7AD-8600FA739E05}</string>
			<BinaryString name="AttributesSerialize"></BinaryString>
			<SecurityCapabilities name="Capabilities">0</SecurityCapabilities>
			<bool name="DefinesCapabilities">false</bool>
			<string name="Name">Studio Memory Optimizer</string>
			<int64 name="SourceAssetId">-1</int64>
			<BinaryString name="Tags"></BinaryString>
		</Properties>
	</Item>
</roblox>
